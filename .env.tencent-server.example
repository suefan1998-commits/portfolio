# Copy this file to .env.tencent-server and fill in the real server values.
# .env.tencent-server is ignored by Git.
TENCENT_SERVER_HOST=
TENCENT_SERVER_USER=root
TENCENT_SERVER_PORT=22
TENCENT_SERVER_PATH=/var/www/sufan-portfolio
TENCENT_SERVER_SSH_KEY=

# Leave empty before ICP approval. Example: 京ICP备XXXXXXXX号-X
ICP_BEIAN_TEXT=
